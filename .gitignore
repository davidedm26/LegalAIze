# ==============================================================================
# LegalAIze - Git Ignore Rules
# ==============================================================================
# Files and directories excluded from version control to keep the repository
# clean, secure, and focused on source code.
# ==============================================================================

# ------------------------------------------------------------------------------
# Python Runtime & Cache
# ------------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/

# Virtual Environments
env/
venv/
ENV/
.venv
backend/backend_venv/
frontend/frontend_venv/

# Jupyter Notebooks
.ipynb_checkpoints/
*.ipynb

# ------------------------------------------------------------------------------
# Machine Learning & Experiment Tracking
# ------------------------------------------------------------------------------
# MLflow experiment tracking
mlruns/
mlartifacts/

# Model artifacts (too large for git)
/models/*.pkl
/models/*.h5
/models/*.pth
/models/*.joblib

# Metrics and evaluation outputs
metrics/**
!metrics/.gitkeep

# ------------------------------------------------------------------------------
# Data Version Control (DVC)
# ------------------------------------------------------------------------------
.dvc/config.local
.dvc/tmp
.dvc/cache

# DVC-tracked large files (tracked via .dvc files instead)
/data/*.csv
/data/*.pdf
data/qdrant_storage/
data/processed/*
data/debug/*
data/ground_truth/raw_data/**
data/unused/**
data/raw_data/*.pdf
data/raw_data/*.html

# Data mapping (generated, not source)
data/mapping.json

# ------------------------------------------------------------------------------
# Development Tools & IDEs
# ------------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*.swn
.project
.pydevproject
.settings/

# ------------------------------------------------------------------------------
# Operating System Files
# ------------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
*.bak
*~

# ------------------------------------------------------------------------------
# Security & Credentials (NEVER commit!)
# ------------------------------------------------------------------------------
.env
*.key
*.pem
*.crt
dagshub_token.txt
secrets/

# ------------------------------------------------------------------------------
# Logs & Temporary Files
# ------------------------------------------------------------------------------
*.log
*.tmp
tmp/
logs/
*.pid

# Docker logs
docker-compose.override.yml

# ------------------------------------------------------------------------------
# Testing & Coverage
# ------------------------------------------------------------------------------
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# ------------------------------------------------------------------------------
# Application-Specific
# ------------------------------------------------------------------------------
backend/debug_responses/

# ------------------------------------------------------------------------------
# Archives (typically not source code)
# ------------------------------------------------------------------------------
*.zip
*.tar
*.tar.gz
*.rar
*.7z
